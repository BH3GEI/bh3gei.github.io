 0;\n  list-style: none;\n}\n\nbutton:hover {\n  background-color: white; \n  color: black; \n  border: 2px solid #4CAF50;\n}\n\n#app {\n  position: absolute;\n  top: 0;\n  left: 0;\n  bottom: 0;\n  right: 0;\n  /* height: calc(100vh - 2 * (20px)); */\n  height: 100vh;\n  /*margin: 20px 0;*/\n  background-size: cover;\n  background-position: center;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  backdrop-filter: blur(100px);\n}\n\n#app::before {\n  content: \"\";\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  background-image: url(https://api.vvhan.com/api/view);\n  background-size: cover;\n  background-position: center;\n  filter: blur(5px);\n  z-index: -1;\n}\n\n.center-box {\n  text-align: center;\n  padding: 20px;\n  background-color: rgba(0, 0, 0, 0.5); \n  backdrop-filter: blur(10px); \n  color: white; \n  transition: all 0.5s ease-in-out;  \n}\n\n.link-list a {\n  display: block;\n  margin: 10px 0;\n  color: white; \n}\n\n@media screen and (max-width: 600px) {\n  .center-box {\n    padding: 10px;\n  }\n}\ndetails {\n  position: relative;\n  transition: all 0.5s ease-in-out;\n  width: 300px;  \n}\n\n.powered-by {\n  position: fixed;\n  right: 30px;\n  bottom: 10px;\n  font-size: 12px;\n  color: white;\n}\n\n/* 鼠标样式\nbody {\n  cursor: url('earth.gif'), auto;\n} */\n\n</style>"],"mappings":"AA2BA,eAAe;EACbA,IAAIA,CAAA,EAAG;IACL,OAAO,CACP;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACRC,QAAQ,CAACC,KAAI,GAAI,eAAe;EAClC;AACF"},"metadata":{},"sourceType":"module","externalDependencies":[]}